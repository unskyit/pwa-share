{
  "name": "MYR PDF Extract",
  "short_name": "PDF to ZIP",
  "start_url": "./",
  "display": "standalone",
  "background_color": "#F2F2F7",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "https://cdn-icons-png.flaticon.com/512/337/337946.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "pdf_files",
          "accept": ["application/pdf", ".pdf"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "Quick Note Widget",
      "short_name": "Note",
      "description": "Jot down a fast local note",
      "url": "./?mode=widget",
      "icons": [{"src": "https://cdn-icons-png.flaticon.com/512/337/337946.png", "sizes": "512x512"}]
    }
  ]
}
